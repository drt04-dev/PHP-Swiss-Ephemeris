{
    "name": "drt04-dev/php-swiss-ephemeris",
    "description": "Modern PHP 8.4+ Object-Oriented Wrapper for Swiss Ephemeris",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-swephp": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Sweph\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sweph\\Tests\\": "tests/"
        }
    }
}
